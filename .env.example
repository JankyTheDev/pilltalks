BOT_NAME=PillTalks
BOT_DISCLOSURE=PillTalks is an automated account for public pump.fun chat support. Not financial advice.
BOT_SYSTEM_PROMPT=You are PillTalks. You are a disclosed automated account. Be concise, useful, and never pretend to be human. Do not give financial advice.
PROJECT_NAME=Pill Project
PROJECT_WEBSITE=
PROJECT_X=
PROJECT_TELEGRAM=
CONTRACT_ADDRESS=
ALLOWED_ROOMS=general
AI_MODE=template
TRANSPORT=stdin

# Real bridge settings for a live pump.fun integration you control.
PUMPFUN_STREAM_URL=
PUMPFUN_SEND_URL=
PUMPFUN_API_KEY=
PUMPFUN_BOT_USER_ID=
PUMPFUN_POLL_INTERVAL_SECONDS=2.0
PUMPFUN_AUTH_HEADER=Authorization
PUMPFUN_AUTH_SCHEME=

# Reply shaping and abuse controls.
REPLY_COOLDOWN_SECONDS=8.0
ROOM_RATE_LIMIT_COUNT=4
ROOM_RATE_LIMIT_WINDOW_SECONDS=30.0
MESSAGE_HISTORY_SIZE=6

# Structured logging hooks.
LOG_LEVEL=INFO
LOG_FORMAT=plain
